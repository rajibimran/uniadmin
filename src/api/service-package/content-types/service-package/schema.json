{
  "kind": "collectionType",
  "collectionName": "service_packages",
  "info": {
    "singularName": "service-package",
    "pluralName": "service-packages",
    "displayName": "Service Package"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "featureLines": {
      "type": "component",
      "repeatable": true,
      "component": "service.simple-line",
      "required": false
    },
    "pricing": {
      "type": "string",
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  },
  "config": {
    "metadatas": {
      "featureLines": {
        "edit": {
          "label": "Package features",
          "description": "Click “Add an entry” for each bullet. One short line per feature (no JSON)."
        },
        "list": { "label": "Features" }
      }
    }
  }
}