{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Catalog-style offerings (non–e-commerce): specs, gallery, downloads."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "brochureFile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "specificationFile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "categoryLabel": {
      "type": "string"
    },
    "order": {
      "type": "integer"
    },
    "seo": {
      "type": "component",
      "component": "seo.entry",
      "repeatable": false
    }
  }
}
