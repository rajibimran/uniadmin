{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "quote": {
      "type": "text",
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  },
  "config": {
    "metadatas": {
      "photo": {
        "edit": {
          "label": "Photo (400x400px)",
          "description": "Square portrait; about 400×400px, ≤100 KB."
        },
        "list": { "label": "Photo (400x400px)" }
      }
    }
  }
}