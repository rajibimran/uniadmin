{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Team member",
    "description": "People / leadership grid for agency, studio, or professional services sites."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "designation": {
      "type": "string",
      "required": true
    },
    "bio": {
      "type": "richtext"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "email": {
      "type": "email"
    },
    "linkedinUrl": {
      "type": "string"
    },
    "order": {
      "type": "integer"
    },
    "seo": {
      "type": "component",
      "component": "seo.entry",
      "repeatable": false
    }
  }
}
