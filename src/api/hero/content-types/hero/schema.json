{
  "kind": "collectionType",
  "collectionName": "heroes",
  "info": {
    "singularName": "hero",
    "pluralName": "heroes",
    "displayName": "Hero",
    "description": "Per-page hero: title, subtitle, slide deck. Put CTAs on each **Hero slide** (per-slide offers/links). Optional root CTAs below are a legacy fallback when a slide has none (e.g. promo video)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "page": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": { "type": "string", "required": true },
    "subtitle": { "type": "text", "required": true },
    "slideItems": {
      "type": "component",
      "repeatable": true,
      "component": "hero.slide",
      "required": false
    },
    "ctaButtons": {
      "type": "component",
      "repeatable": true,
      "component": "hero.cta-button",
      "required": false
    },
    "promoVideo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["videos"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.entry",
      "required": false
    },
    "faqs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq.faq",
      "mappedBy": "sitePage"
    }
  },
  "config": {
    "metadatas": {
      "slideItems": {
        "edit": {
          "label": "Slides",
          "description": "Add slides in order. Each slide: image (~1600×900), title, text, and its own **CTA buttons** (unlimited per slide). Use root CTAs only as a fallback for slides with no buttons."
        },
        "list": { "label": "Slides" }
      }
    }
  }
}
