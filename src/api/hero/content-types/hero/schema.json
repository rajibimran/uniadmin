{
  "kind": "collectionType",
  "collectionName": "heroes",
  "info": {
    "singularName": "hero",
    "pluralName": "heroes",
    "displayName": "Hero",
    "description": "Per-page hero: title, subtitle, slide deck, CTAs"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "page": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": { "type": "string", "required": true },
    "subtitle": { "type": "text", "required": true },
    "slideItems": {
      "type": "component",
      "repeatable": true,
      "component": "hero.slide",
      "required": false
    },
    "ctaButtons": {
      "type": "component",
      "repeatable": true,
      "component": "hero.cta-button"
    },
    "promoVideo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["videos"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.entry",
      "required": false
    }
  },
  "config": {
    "metadatas": {
      "slideItems": {
        "edit": {
          "label": "Slides",
          "description": "Add slides in order. Each slide: image (~1600×900), title, and text shown when that slide is active."
        },
        "list": { "label": "Slides" }
      }
    }
  }
}
