{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Blog Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": false
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.entry",
      "required": false
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "date": {
      "type": "date",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Guide",
        "Tips",
        "Education",
        "Technology"
      ],
      "required": true
    }
  },
  "config": {
    "metadatas": {
      "image": {
        "edit": {
          "label": "Featured image (900x600px)",
          "description": "About 900×600px, ≤120 KB."
        },
        "list": { "label": "Featured image (900x600px)" }
      },
      "seo": {
        "edit": {
          "label": "SEO — search, social & schema",
          "description": "Meta title & description, canonical, Open Graph image (Media), Twitter card, JSON-LD, robots, AI/overview snippet."
        },
        "list": { "label": "SEO" }
      }
    }
  }
}
