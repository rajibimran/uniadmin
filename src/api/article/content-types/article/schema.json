{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Blog Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": false
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.entry",
      "required": false
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "date": {
      "type": "date",
      "required": true
    },
    "postCategory": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::post-category.post-category",
      "inversedBy": "articles"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "commentsOpen": {
      "type": "boolean",
      "default": true
    }
  },
  "config": {
    "metadatas": {
      "image": {
        "edit": {
          "label": "Featured image (900x600px)",
          "description": "About 900×600px, ≤120 KB."
        },
        "list": { "label": "Featured image (900x600px)" }
      },
      "seo": {
        "edit": {
          "label": "SEO — search, social & schema",
          "description": "Meta title & description, canonical, Open Graph image (Media), Twitter card, JSON-LD, robots, AI/overview snippet."
        },
        "list": { "label": "SEO" }
      },
      "isFeatured": {
        "edit": {
          "label": "Featured (blog)",
          "description": "Only one blog article should be featured at a time; saving clears others automatically."
        },
        "list": { "label": "Featured" }
      },
      "commentsOpen": {
        "edit": {
          "label": "Allow comments",
          "description": "Also requires **Comments enabled** in Site Config."
        },
        "list": { "label": "Comments" }
      }
    }
  }
}
