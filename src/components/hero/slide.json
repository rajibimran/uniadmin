{
  "collectionName": "components_hero_slides",
  "info": {
    "displayName": "Hero slide",
    "description": "One hero carousel slide: image, headline, text, and optional CTAs for this slide only."
  },
  "options": {},
  "attributes": {
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "title": {
      "type": "string",
      "required": true
    },
    "text": {
      "type": "text",
      "required": true
    },
    "ctaButtons": {
      "type": "component",
      "repeatable": true,
      "component": "hero.cta-button",
      "required": false
    }
  }
}
